# Vigor AI - Environment Configuration (Example)
# Copy this file to .env and fill in your values

# Application
APP_NAME=Vigor AI
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=True

# AI Model Configuration
# Recommended models (with estimated size):
# - microsoft/Phi-3-mini-4k-instruct (3.8B, ~8GB / 4GB with 4-bit) - Best quality/size ratio
# - mistralai/Mistral-7B-Instruct-v0.2 (7B, ~14GB / 4GB with 4-bit) - High quality
# - TheBloke/Mistral-7B-Instruct-v0.2-GGUF (GGUF format, 4GB quantized) - Best for CPU
# - TinyLlama/TinyLlama-1.1B-Chat-v1.0 (1.1B, ~2GB) - Minimal size
MODEL_NAME=microsoft/Phi-3-mini-4k-instruct
MODEL_PATH=./models/downloaded
CACHE_DIR=./models/cache
MAX_TOKENS=4096
TEMPERATURE=0.7

# Hugging Face Token (Optional - only needed for gated models)
# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACE_HUB_TOKEN=your_huggingface_token_here

# Model Backend & Quantization (auto-detection recommended)
# MODEL_TYPE options: auto, transformers, airllm, gguf, vllm
# QUANTIZATION options: auto, none, 4bit, 8bit
MODEL_TYPE=gguf
QUANTIZATION=auto

# GPU Configuration (set to False for CPU-only)
USE_GPU=False
GPU_DEVICE=0
ROCM_PATH=/opt/rocm
HIP_VISIBLE_DEVICES=0

# Vector Database
CHROMA_PERSIST_DIR=./data/embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Document Processing
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE=52428800  # 50MB
ALLOWED_EXTENSIONS=.pdf,.docx,.txt

# Citation Management
CITATION_DIR=./data/citations
DEFAULT_CITATION_STYLE=IEEE

# Security
# IMPORTANT: Change this in production!
SECRET_KEY=generate-a-secure-random-key-here
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
